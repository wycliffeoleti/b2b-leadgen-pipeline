# Application
DEBUG=false

# Claude API
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_LOG=info

# n8n (workflow orchestration)
N8N_BASE_URL=http://localhost:5678

# Apify (scraping — optional, install with: uv sync --extra scraping)
APIFY_TOKEN=your-apify-token-here

# Alerting
SLACK_ALERT_WEBHOOK=

# Gemini (used by the lead qualifier)
GEMINI_API_KEY=your-gemini-key-here

# Hugging Face MCP server (optional)
HF_TOKEN=your-hf-token-here
